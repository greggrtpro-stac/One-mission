// ─────────────────────────────────────────────────────────────
// One Mission — Schéma de base de données
// ─────────────────────────────────────────────────────────────

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ── Enums ────────────────────────────────────────────────────

enum QuestCategory {
  SPORT
  TRAVAIL
  ETUDES
  SANTE
  PERSO
  FINANCE
  AUTRE
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum Difficulty {
  TRIVIAL // 10 XP
  EASY // 25 XP
  MEDIUM // 50 XP
  HARD // 100 XP
  EPIC // 200 XP
}

enum QuestStatus {
  TODO
  IN_PROGRESS
  DONE
  CANCELLED
}

enum SessionKind {
  FOCUS
  SHORT_BREAK
  LONG_BREAK
}

enum CoachRole {
  USER
  ASSISTANT
}

// ── Utilisateurs & auth ──────────────────────────────────────

model User {
  id           String  @id @default(cuid())
  email        String  @unique
  passwordHash String? // null si le compte n'existe que via Google
  googleId     String? @unique
  username     String  @unique
  firstName    String?
  lastName     String?
  avatarUrl    String?
  theme        String  @default("dark")

  // Gamification (autorité serveur)
  level          Int       @default(1)
  totalXp        Int       @default(0)
  currentXp      Int       @default(0)
  currentStreak  Int       @default(0)
  longestStreak  Int       @default(0)
  lastActivityAt DateTime?

  // Préférences DeepWork { focusMinutes, shortBreakMinutes, longBreakMinutes, cyclesBeforeLongBreak }
  deepWorkSettings Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  quests           Quest[]
  mainQuest        MainQuest?
  weeklyQuests     WeeklyQuest[]
  deepWorkSessions DeepWorkSession[]
  addictions       Addiction[]
  journalEntries   JournalEntry[]
  refreshTokens    RefreshToken[]
  passwordResets   PasswordResetToken[]
}

model RefreshToken {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// ── Quêtes ───────────────────────────────────────────────────

model Quest {
  id          String        @id @default(cuid())
  userId      String
  title       String
  description String?
  category    QuestCategory @default(AUTRE)
  priority    Priority      @default(MEDIUM)
  difficulty  Difficulty    @default(MEDIUM)
  dueDate     DateTime      @db.Date
  dueTime     String? // "HH:mm", facultatif
  status      QuestStatus   @default(TODO)
  progress    Int           @default(0) // 0–100
  xpAwarded   Int           @default(0) // XP réellement versée (idempotence)
  completedAt DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, dueDate])
  @@index([userId, status])
}

model MainQuest {
  id          String    @id @default(cuid())
  userId      String    @unique // une seule quête principale par joueur
  title       String
  description String?
  targetDate  DateTime?
  progress    Int       @default(0) // 0–100
  milestones  Json? // [{ id, title, done }]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model WeeklyQuest {
  id               String     @id @default(cuid())
  userId           String
  title            String
  description      String?
  difficulty       Difficulty @default(MEDIUM)
  sortOrder        Int        @default(0)
  isActive         Boolean    @default(true) // archivage : jamais supprimée après complétion
  completedAt      DateTime? // complétion de la semaine en cours
  weekStart        DateTime // lundi (UTC) de la semaine de référence
  totalCompletions Int        @default(0)
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isActive])
}

// ── DeepWork ─────────────────────────────────────────────────

model DeepWorkSession {
  id        String      @id @default(cuid())
  userId    String
  startedAt DateTime
  duration  Int // secondes effectives
  kind      SessionKind @default(FOCUS)
  completed Boolean     @default(true)
  createdAt DateTime    @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, startedAt])
}

// ── Addictions ───────────────────────────────────────────────

model Addiction {
  id           String   @id @default(cuid())
  userId       String
  name         String
  icon         String? // nom d'icône lucide
  startDate     DateTime // début de la série en cours
  relapseCount  Int      @default(0)
  bestStreak    Int      @default(0) // record en jours
  lastMilestone Int      @default(0) // dernier palier (jours) déjà récompensé en XP
  shareJournal  Boolean  @default(false) // le coach IA peut lire le journal
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  relapses      Relapse[]
  coachMessages CoachMessage[]

  @@index([userId])
}

/// Conversation avec le coach IA — un fil par addiction.
model CoachMessage {
  id          String    @id @default(cuid())
  addictionId String
  role        CoachRole
  content     String    @db.Text
  createdAt   DateTime  @default(now())

  addiction Addiction @relation(fields: [addictionId], references: [id], onDelete: Cascade)

  @@index([addictionId, createdAt])
}

model Relapse {
  id          String   @id @default(cuid())
  addictionId String
  occurredAt  DateTime @default(now())
  streakLost  Int // jours perdus au moment de la rechute
  note        String?

  addiction Addiction @relation(fields: [addictionId], references: [id], onDelete: Cascade)

  @@index([addictionId, occurredAt])
}

// ── Journal ──────────────────────────────────────────────────

model JournalEntry {
  id         String   @id @default(cuid())
  userId     String
  date       DateTime @db.Date
  content    String   @db.Text
  aiAnalysis Json? // { score, summary, positives[], improvements[], advice[] }
  aiScore    Int? // note /10
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
}

// ── Divers ───────────────────────────────────────────────────

model Quote {
  id     String  @id @default(cuid())
  text   String
  author String?
}
