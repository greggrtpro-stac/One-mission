// ─────────────────────────────────────────────────────────────
// One Mission — Schéma de base de données
// ─────────────────────────────────────────────────────────────

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ── Enums ────────────────────────────────────────────────────

enum QuestCategory {
  SPORT
  TRAVAIL
  ETUDES
  SANTE
  PERSO
  FINANCE
  AUTRE
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum Difficulty {
  TRIVIAL // 10 XP
  EASY // 25 XP
  MEDIUM // 50 XP
  HARD // 100 XP
  EPIC // 200 XP
}

enum QuestStatus {
  TODO
  IN_PROGRESS
  DONE
  CANCELLED
}

enum SessionKind {
  FOCUS
  SHORT_BREAK
  LONG_BREAK
}

enum CoachRole {
  USER
  ASSISTANT
}

enum PlanningEventStatus {
  PLANNED
  DONE
  CANCELLED
}

enum PlanTier {
  STARTER
  PRO
  MAX
}

enum SubscriptionStatus {
  ACTIVE
  TRIALING
  PAST_DUE
  CANCELED
  EXPIRED
}

enum BillingCycle {
  MONTHLY
  YEARLY
}

enum FeedbackCategory {
  BUG
  SUGGESTION
  UI
  PERFORMANCE
  OTHER
}

enum FeedbackPriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum SubscriptionEventType {
  CREATED
  UPGRADED
  DOWNGRADED
  CYCLE_CHANGED
  RENEWED
  CANCELED
  REACTIVATED
  EXPIRED
}

// ── Utilisateurs & auth ──────────────────────────────────────

model User {
  id           String  @id @default(cuid())
  email        String  @unique
  passwordHash String? // null si le compte n'existe que via Google
  googleId     String? @unique
  username     String  @unique
  firstName    String?
  lastName     String?
  phone        String?
  avatarUrl    String?
  theme        String  @default("dark")
  language     String  @default("fr")

  // Préférences de notifications { questReminders, weeklyRecap, coachMessages }
  notifications     Json?
  showOnLeaderboard Boolean @default(true)

  // Communication & notifications marketing (opt-in RGPD, distinct des
  // notifications produit ci-dessus). communicationPrefs :
  // { productUpdates, productivityTips, featureAnnouncements, promotionalOffers, accountSecurity }
  newsletterOptIn    Boolean @default(false)
  communicationPrefs Json?

  // Vérification d'e-mail (architecture prête, non bloquante : null = non vérifié)
  emailVerifiedAt DateTime?

  // Sécurité — architecture 2FA par SMS (préparée, pas encore activable côté client)
  twoFactorEnabled         Boolean   @default(false)
  twoFactorSecret          String?
  twoFactorPhone           String? // numéro dédié au 2FA (distinct du champ profil)
  twoFactorPhoneVerifiedAt DateTime?

  // Gamification (autorité serveur)
  level          Int       @default(1)
  totalXp        Int       @default(0)
  currentXp      Int       @default(0)
  currentStreak  Int       @default(0)
  longestStreak  Int       @default(0)
  lastActivityAt DateTime?

  // Préférences DeepWork { focusMinutes, shortBreakMinutes, longBreakMinutes, cyclesBeforeLongBreak }
  deepWorkSettings Json?

  // Amis & présence. friendPrefs (null = tout autorisé, voir DEFAULT_FRIEND_PREFS) :
  // { allowFriendRequests, allowUsernameSearch, showOnlineStatus, showLastSeen, showAddictionsPublicly }
  friendPrefs Json?
  lastSeenAt  DateTime? // dernière requête authentifiée (throttlé, voir middleware/auth.ts)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  quests           Quest[]
  questCompletions QuestCompletion[]
  mainQuest        MainQuest?
  weeklyQuests     WeeklyQuest[]
  routineSections  RoutineSection[]
  routineTasks     RoutineTask[]
  routineChecks    RoutineCheck[]
  planningEvents     PlanningEvent[]
  planningCategories PlanningCategory[]
  deepWorkSessions DeepWorkSession[]
  addictions       Addiction[]
  journalEntries   JournalEntry[]
  refreshTokens      RefreshToken[]
  passwordResets     PasswordResetToken[]
  emailVerifications EmailVerificationToken[]
  twoFactorCodes     TwoFactorCode[]
  subscription       Subscription?
  feedbacks          Feedback[]
  sentFriendRequests     FriendRequest[] @relation("FriendRequestSender")
  receivedFriendRequests FriendRequest[] @relation("FriendRequestReceiver")
  friendshipsA           Friendship[]    @relation("FriendshipUserA")
  friendshipsB           Friendship[]    @relation("FriendshipUserB")
  notificationsInbox     Notification[]
}

// ── Amis ─────────────────────────────────────────────────────

// Demande d'ami en attente. Acceptée → devient une Friendship et disparaît ;
// refusée ou annulée → supprimée. L'unicité (sender, receiver) interdit les
// doublons ; le sens inverse est vérifié en service avant création.
model FriendRequest {
  id         String   @id @default(cuid())
  senderId   String
  receiverId String
  createdAt  DateTime @default(now())

  sender   User @relation("FriendRequestSender", fields: [senderId], references: [id], onDelete: Cascade)
  receiver User @relation("FriendRequestReceiver", fields: [receiverId], references: [id], onDelete: Cascade)

  @@unique([senderId, receiverId])
  @@index([receiverId, createdAt])
}

// Amitié établie — une seule ligne par paire, avec la convention
// userAId < userBId (ordre lexicographique) pour rendre le doublon
// (B, A) impossible par contrainte d'unicité.
model Friendship {
  id        String   @id @default(cuid())
  userAId   String
  userBId   String
  createdAt DateTime @default(now())

  userA User @relation("FriendshipUserA", fields: [userAId], references: [id], onDelete: Cascade)
  userB User @relation("FriendshipUserB", fields: [userBId], references: [id], onDelete: Cascade)

  @@unique([userAId, userBId])
  @@index([userBId])
}

// ── Notifications (centre de notifications à venir) ─────────

enum NotificationType {
  FRIEND_REQUEST_RECEIVED
  FRIEND_REQUEST_ACCEPTED
  FRIEND_REQUEST_DECLINED
}

model Notification {
  id        String           @id @default(cuid())
  userId    String // destinataire
  type      NotificationType
  data      Json? // charge utile libre ({ fromUserId, fromUsername… })
  readAt    DateTime?
  createdAt DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

// ── Bêta : signalements des testeurs ─────────────────────────

/// Signalement envoyé via le bouton « Signaler un bug » : consultable en base
/// (npm run db:studio) ; le statut est un suivi manuel de l'éditeur.
model Feedback {
  id          String           @id @default(cuid())
  userId      String
  title       String
  description String           @db.Text
  category    FeedbackCategory @default(BUG)
  priority    FeedbackPriority @default(MEDIUM)
  page        String? // route de l'app où le signalement a été fait
  screenshot  String? // capture d'écran compressée (data-URL), optionnelle
  status      String           @default("NEW") // NEW / IN_PROGRESS / DONE
  createdAt   DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([createdAt])
}

// ── Abonnements ──────────────────────────────────────────────

/// Un abonnement par utilisateur, créé paresseusement (STARTER par défaut).
/// Les champs stripe* restent null tant que le paiement n'est pas branché :
/// l'intégration Stripe viendra les remplir sans toucher au reste du modèle.
model Subscription {
  id     String             @id @default(cuid())
  userId String             @unique
  plan   PlanTier           @default(STARTER)
  status SubscriptionStatus @default(ACTIVE)

  billingCycle      BillingCycle @default(MONTHLY)
  startedAt         DateTime     @default(now()) // début de l'abonnement en cours
  currentPeriodEnd  DateTime? // date de renouvellement (gérée par Stripe plus tard)
  cancelAtPeriodEnd Boolean      @default(false)
  trialEndsAt       DateTime? // périodes d'essai (préparé, pas encore utilisé)

  // Réservé à l'intégration paiement (Stripe)
  stripeCustomerId     String? @unique
  stripeSubscriptionId String? @unique
  stripePriceId        String?
  promoCode            String? // codes promotionnels (préparé)
  discountPercent      Int? // remises (préparé)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user   User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  events SubscriptionEvent[]
}

/// Historique des changements d'abonnement (audit + affichage Level Up).
model SubscriptionEvent {
  id             String                @id @default(cuid())
  subscriptionId String
  type           SubscriptionEventType
  fromPlan       PlanTier?
  toPlan         PlanTier
  note           String?
  createdAt      DateTime              @default(now())

  subscription Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)

  @@index([subscriptionId, createdAt])
}

model RefreshToken {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())

  // Session d'appareil : les tokens sont rotatifs, familyId reste stable à
  // travers les rotations et identifie la session dans « Appareils connectés ».
  familyId    String   @default(cuid())
  userAgent   String?
  ip          String?
  connectedAt DateTime @default(now()) // première connexion de l'appareil
  lastUsedAt  DateTime @default(now()) // dernière rotation (activité)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([familyId])
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

/// Vérification d'adresse e-mail (préparée — même cycle de vie que le reset :
/// hash seul en base, usage unique, expiration, suppression après usage).
model EmailVerificationToken {
  id        String   @id @default(cuid())
  userId    String
  tokenHash String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

/// À quoi sert un code 2FA temporaire.
enum TwoFactorPurpose {
  ENROLLMENT // vérification du numéro à l'activation
  LOGIN // second facteur à la connexion
  DISABLE // confirmation de désactivation
}

/// Codes 2FA SMS temporaires (préparés — jamais de code en clair : hash seul,
/// expiration courte, usage unique, tentatives comptées contre le brute force).
model TwoFactorCode {
  id        String           @id @default(cuid())
  userId    String
  codeHash  String
  purpose   TwoFactorPurpose @default(LOGIN)
  attempts  Int              @default(0)
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, purpose])
}

// ── Quêtes ───────────────────────────────────────────────────

model Quest {
  id          String        @id @default(cuid())
  userId      String
  title       String
  description String?
  category    QuestCategory @default(AUTRE)
  priority    Priority      @default(MEDIUM)
  difficulty  Difficulty    @default(MEDIUM)
  dueDate     DateTime      @db.Date
  dueTime     String? // "HH:mm", facultatif
  status      QuestStatus   @default(TODO)
  progress    Int           @default(0) // 0–100
  xpAwarded   Int           @default(0) // XP réellement versée (idempotence)
  completedAt DateTime?
  // Posé par la migration 20260706164006 (branche quêtes journalières) :
  // nombre total de jours où la quête a été réalisée. Inutilisé par main
  // tant que la branche n'est pas mergée.
  totalCompletions Int @default(0)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  planningEvent PlanningEvent?
  completions   QuestCompletion[]

  @@index([userId, dueDate])
  @@index([userId, status])
}

/// Historique des accomplissements journaliers : une ligne par quête et par
/// jour réalisé. Survit au reset quotidien (et à la suppression de la quête)
/// pour alimenter les statistiques : complétions, XP, séries, taux de réussite.
/// Table posée par la branche quêtes journalières (migration 20260706164006) ;
/// le code de main ne l'exploite pas encore.
model QuestCompletion {
  id          String        @id @default(cuid())
  userId      String
  questId     String? // null si la quête a été supprimée depuis
  category    QuestCategory
  xpAwarded   Int
  completedAt DateTime

  user  User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  quest Quest? @relation(fields: [questId], references: [id], onDelete: SetNull)

  @@index([userId, completedAt])
  @@index([questId])
}

// ── Planning ─────────────────────────────────────────────────

/// Catégorie de planning propre à un utilisateur (nom, couleur, icône libres).
/// Remplace l'ancien enum figé QuestCategory pour les événements de Planning —
/// celui-ci reste utilisé tel quel par Quest/QuestCompletion, systèmes découplés.
/// isDefault marque la catégorie de repli ("Autre") : toujours exactement une
/// par utilisateur, jamais zéro (voir planning-categories.service.ts).
model PlanningCategory {
  id        String   @id @default(cuid())
  userId    String
  name      String
  color     String // hex "#RRGGBB"
  icon      String  @default("📁") // emoji libre, jamais vide
  isDefault Boolean  @default(false)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user   User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  events PlanningEvent[]

  @@unique([userId, name])
  @@index([userId, sortOrder])
}

/// Événement du calendrier hebdomadaire. Peut être lié à une quête (questId) :
/// le statut de l'événement est alors synchronisé avec celui de la quête
/// (complétion, décomplétion). Si la quête est supprimée, l'événement redevient
/// un événement libre (questId → null).
model PlanningEvent {
  id          String              @id @default(cuid())
  userId      String
  title       String
  description String?
  notes       String?             @db.Text
  categoryId  String
  priority    Priority            @default(MEDIUM)
  startAt     DateTime // UTC
  endAt       DateTime // UTC, strictement après startAt
  status      PlanningEventStatus @default(PLANNED)
  questId     String?             @unique

  // Rappels — architecture prête, l'envoi réel (push/mail) viendra plus tard.
  reminderMinutes Int? // minutes avant startAt, null = pas de rappel
  reminderSentAt  DateTime? // idempotence de l'envoi futur

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user             User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  quest            Quest?           @relation(fields: [questId], references: [id], onDelete: SetNull)
  // Pas de onDelete ici (Restrict par défaut) : la suppression d'une catégorie
  // encore référencée doit être bloquée par la base tant que le service n'a
  // pas explicitement réaffecté ou supprimé ses événements (jamais de perte
  // silencieuse — voir planning-categories.service.ts#deleteCategory).
  planningCategory PlanningCategory @relation(fields: [categoryId], references: [id])

  @@index([userId, startAt])
  @@index([categoryId])
}

model MainQuest {
  id          String    @id @default(cuid())
  userId      String    @unique // une seule quête principale par joueur
  title       String
  description String?
  targetDate  DateTime?
  progress    Int       @default(0) // 0–100
  milestones  Json? // [{ id, title, done }]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model WeeklyQuest {
  id               String     @id @default(cuid())
  userId           String
  title            String
  description      String?
  difficulty       Difficulty @default(MEDIUM)
  sortOrder        Int        @default(0)
  isActive         Boolean    @default(true) // archivage : jamais supprimée après complétion
  completedAt      DateTime? // complétion de la semaine en cours
  weekStart        DateTime // lundi (UTC) de la semaine de référence
  totalCompletions Int        @default(0)
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isActive])
}

// ── Routines ─────────────────────────────────────────────────
// Suivi d'habitudes indépendant des quêtes : aucune XP n'est attribuée.
// Les coches sont scopées par semaine (weekStart) : une nouvelle semaine
// démarre naturellement à zéro (aucune tâche planifiée, aucun job requis) ;
// l'historique des semaines passées reste en base pour calculer la série.

/// Section par défaut ("Morning Routine" / "Night Routine"), créée
/// paresseusement au premier chargement de l'utilisateur (voir routines.service.ts).
model RoutineSection {
  id        String   @id @default(cuid())
  userId    String
  title     String
  icon      String? // emoji d'illustration ("🌅", "🌙")
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user  User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  tasks RoutineTask[]

  @@index([userId])
}

model RoutineTask {
  id        String   @id @default(cuid())
  userId    String
  sectionId String
  title     String
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user    User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  section RoutineSection @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  checks  RoutineCheck[]

  @@index([sectionId])
  @@index([userId])
}

/// Une coche = une tâche cochée un jour précis d'une semaine précise.
/// La ligne n'existe que si la case est cochée (upsert au coche, delete au
/// décoche) : compter les lignes d'une semaine donne directement sa progression.
model RoutineCheck {
  id        String   @id @default(cuid())
  userId    String
  taskId    String
  weekStart DateTime // lundi (UTC) de la semaine concernée
  dayOfWeek Int // 0 = lundi … 6 = dimanche
  checkedAt DateTime @default(now())

  user User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  task RoutineTask @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@unique([taskId, weekStart, dayOfWeek])
  @@index([userId, weekStart])
}

// ── DeepWork ─────────────────────────────────────────────────

model DeepWorkSession {
  id        String      @id @default(cuid())
  userId    String
  startedAt DateTime
  duration  Int // secondes effectives
  kind      SessionKind @default(FOCUS)
  completed Boolean     @default(true)
  createdAt DateTime    @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, startedAt])
}

// ── Addictions ───────────────────────────────────────────────

model Addiction {
  id           String   @id @default(cuid())
  userId       String
  name         String
  icon         String? // nom d'icône lucide
  startDate     DateTime // début de la série en cours
  relapseCount  Int      @default(0)
  bestStreak    Int      @default(0) // record en jours
  lastMilestone Int      @default(0) // dernier palier (jours) déjà récompensé en XP
  shareJournal  Boolean  @default(false) // le coach IA peut lire le journal
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  relapses      Relapse[]
  coachMessages CoachMessage[]

  @@index([userId])
}

/// Conversation avec le coach IA — un fil par addiction.
model CoachMessage {
  id          String    @id @default(cuid())
  addictionId String
  role        CoachRole
  content     String    @db.Text
  createdAt   DateTime  @default(now())

  addiction Addiction @relation(fields: [addictionId], references: [id], onDelete: Cascade)

  @@index([addictionId, createdAt])
}

model Relapse {
  id          String   @id @default(cuid())
  addictionId String
  occurredAt  DateTime @default(now())
  streakLost  Int // jours perdus au moment de la rechute
  note        String?

  addiction Addiction @relation(fields: [addictionId], references: [id], onDelete: Cascade)

  @@index([addictionId, occurredAt])
}

// ── Journal ──────────────────────────────────────────────────

model JournalEntry {
  id         String   @id @default(cuid())
  userId     String
  date       DateTime @db.Date
  content    String   @db.Text
  aiAnalysis Json? // { score, summary, positives[], improvements[], advice[] }
  aiScore    Int? // note /10
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
}

// ── Divers ───────────────────────────────────────────────────

model Quote {
  id     String  @id @default(cuid())
  text   String
  author String?
}
