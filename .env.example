# ── Base de données ─────────────────────────────────────────
DATABASE_URL="postgresql://onemission:onemission_dev@localhost:5433/onemission"

# ── Serveur ─────────────────────────────────────────────────
PORT=4000
CLIENT_URL="http://localhost:5173"
NODE_ENV="development"

# ── JWT (générer des secrets forts en production) ───────────
JWT_ACCESS_SECRET="change-me-access-secret"
JWT_REFRESH_SECRET="change-me-refresh-secret"

# ── Google OAuth (console.cloud.google.com) ─────────────────
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ── Cloudflare Turnstile (dash.cloudflare.com, gratuit) ─────
# Vides = anti-robot désactivé (développement local uniquement).
# Protège : inscription, connexion, mot de passe oublié, renvoi de confirmation.
TURNSTILE_SITE_KEY=""
TURNSTILE_SECRET_KEY=""

# ── IA du journal (console.anthropic.com) ───────────────────
ANTHROPIC_API_KEY=""

# ── Paiement Stripe (dashboard.stripe.com) ──────────────────
# Vides = paiement désactivé : les offres payantes affichent une erreur
# claire et RIEN ne peut être activé. Utiliser les clés de TEST (sk_test_…)
# tant que le site n'est pas en production. Voir README § Paiements Stripe.
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
# Identifiants des tarifs (Produits → Tarifs, price_…) :
STRIPE_PRICE_PRO_MONTHLY=""
STRIPE_PRICE_PRO_YEARLY=""
STRIPE_PRICE_MAX_MONTHLY=""
STRIPE_PRICE_MAX_YEARLY=""

# ── E-mails (réinitialisation de mot de passe) ──────────────
# En développement, laisser vide : les liens sont affichés dans la console serveur.
SMTP_HOST=""
SMTP_PORT=587
SMTP_USER=""
SMTP_PASS=""
MAIL_FROM="One Mission <no-reply@one-mission.fr>"
